generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SiteSettings {
  id              String   @id @default("main")
  fullName        String
  headline        String
  availabilityTag String?  @default("Available for Biomedical + AI + Robotics projects")
  stat1Label      String?  @default("Systems shipped")
  stat1Value      String?  @default("10+")
  stat1Desc       String?  @default("From prototype to production")
  stat2Label      String?  @default("Focus")
  stat2Value      String?  @default("AI + Robotics")
  stat2Desc       String?  @default("Agent systems, automation, productization")
  stat3Label      String?  @default("Collaboration")
  stat3Value      String?  @default("Global")
  stat3Desc       String?  @default("Remote-first execution")
  marqueeItems    String?  @default("⚡ Autonomous Agents|🤖 Robotics Workflow|🧠 AI Product Engineering|🔁 Automation Systems|📊 Reliability + Observability|🚀 Ship Fast, Scale Safely")
  bio             String
  location        String?
  email           String?
  linkedinUrl     String?
  githubUrl       String?
  githubUrl2      String?
  whatsappUrl     String?
  scholarUrl      String?
  researchGateUrl String?
  avatarUrl       String?
  updatedAt       DateTime @updatedAt
}

model Project {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  summary       String
  content       String
  stack         String?
  imageUrl      String?
  demoUrl       String?
  repoUrl       String?
  featured      Boolean   @default(false)
  featuredOrder Int       @default(0)
  sortOrder     Int       @default(0)
  published     Boolean   @default(false)
  publishAt     DateTime?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Post {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  writerName    String?
  category      String    @default("technical")
  excerpt       String
  content       String
  tags          String?
  imageUrl      String?
  coverImages   String?
  sortOrder     Int       @default(0)
  published     Boolean   @default(false)
  publishAt     DateTime?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model AdminUser {
  id                String   @id @default(cuid())
  email             String   @unique
  password          String
  passwordUpdatedAt DateTime @default(now())
  name              String
  role              String   @default("editor")
  active            Boolean  @default(true)
  totpEnabled       Boolean  @default(false)
  totpSecret        String?
  recoveryCodesHash String?
  sessionVersion    Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model LoginThrottle {
  id          String   @id @default(cuid())
  email       String   @unique
  failedCount Int      @default(0)
  lockUntil   DateTime?
  updatedAt   DateTime @updatedAt
}

model MediaAsset {
  id        String   @id @default(cuid())
  url       String
  kind      String   @default("blog")
  createdAt DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actorEmail String?
  actorRole  String?
  action     String
  targetType String
  targetId   String?
  meta       String?
  createdAt  DateTime @default(now())
}
